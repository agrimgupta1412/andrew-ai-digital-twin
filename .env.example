# Gemini API keys
# Fill as many as you have. The app tries the next key if one key hits quota/rate limits.
GOOGLE_API_KEY_1=your_first_google_api_key_here
GOOGLE_API_KEY_2=your_second_google_api_key_here
GOOGLE_API_KEY_3=your_third_google_api_key_here
GOOGLE_API_KEY_4=your_fourth_google_api_key_here

# Optional older single-key layout. You can leave this blank if using the numbered keys above.
GOOGLE_API_KEY=

GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004
REQUEST_TIMEOUT_SECONDS=45
CHROMA_DB_DIR=vectorstore
SQLITE_MEMORY_DB=memory/memory.db
TOP_K=5
USE_BM25=true
RESPONSE_DEPTH=standard
ENABLE_TIMELINE=true
TIMELINE_FILE=data/timeline/andrew_ng_timeline.json
ENABLE_MEMORY_DASHBOARD=true
